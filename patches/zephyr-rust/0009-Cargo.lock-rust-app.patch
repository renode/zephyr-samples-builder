From e1a6c5c546c4759956186728dbb5f19eb4955f89 Mon Sep 17 00:00:00 2001
From: Pawel Reich <preich@internships.antmicro.com>
Date: Mon, 1 Jun 2026 15:18:33 +0200
Subject: [PATCH] Cargo.lock rust-app

---
 CMakeLists.txt              |   2 +-
 rust/build.sh               |   2 +-
 rust/genproject.sh          |   1 +
 samples/rust-app/.gitignore |   1 -
 samples/rust-app/Cargo.lock | 107 ++++++++++++++++++++++++++++++++++++
 5 files changed, 110 insertions(+), 3 deletions(-)
 create mode 100644 samples/rust-app/Cargo.lock

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 75ed0ea..4d935c1 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -95,7 +95,7 @@ if(NOT ZEPHYR_BINDGEN)
         WORKING_DIRECTORY ${zephyr_bindgen_src_dir}
         DEPENDS syscall_thunks_target
         COMMAND
-              cargo -v build --release --target-dir=${zephyr_bindgen_build_dir}
+              cargo --locked -v build --release --target-dir=${zephyr_bindgen_build_dir}
     )
 endif()
 
diff --git a/rust/build.sh b/rust/build.sh
index 8e77186..6d01405 100755
--- a/rust/build.sh
+++ b/rust/build.sh
@@ -45,4 +45,4 @@ RUSTFLAGS="$RUSTFLAGS -Cembed-bitcode=yes" cargo ${CARGO_ARGS} \
 publish_sysroot ${APP_BUILD} ${SYSROOT} ${SYSROOT_BUILD}-stage1
 
 export RUSTFLAGS="${RUSTFLAGS} --sysroot ${SYSROOT}"
-cargo ${CARGO_ARGS} --target-dir=${APP_BUILD} --manifest-path=${CARGO_MANIFEST}
+cargo --locked ${CARGO_ARGS} --target-dir=${APP_BUILD} --manifest-path=${CARGO_MANIFEST}
diff --git a/rust/genproject.sh b/rust/genproject.sh
index b82cc5f..89678c5 100755
--- a/rust/genproject.sh
+++ b/rust/genproject.sh
@@ -22,6 +22,7 @@ crate-type = ["staticlib"]
 [dependencies]
 app = { path = "${crate_dir}" }
 unicode-ident = "=1.0.5"
+log = "=0.4.29"
 [build-dependencies]
 quote = "=1.0.37"
 [profile.release]
diff --git a/samples/rust-app/.gitignore b/samples/rust-app/.gitignore
index 06aba01..ea8c4bf 100644
--- a/samples/rust-app/.gitignore
+++ b/samples/rust-app/.gitignore
@@ -1,2 +1 @@
-Cargo.lock
 /target
diff --git a/samples/rust-app/Cargo.lock b/samples/rust-app/Cargo.lock
new file mode 100644
index 0000000..7a564cf
--- /dev/null
+++ b/samples/rust-app/Cargo.lock
